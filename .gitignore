# Dependencies
node_modules/
mobile/node_modules/

# Build outputs
backend/target/
web/dist/
backend/uploads/
mobile/android/build/
mobile/android/app/build/
mobile/android/.gradle/
mobile/ios/build/
mobile/ios/Pods/
mobile/ios/DerivedData/
mobile/deploy/
# Metro bundler output copied into the Android project by local release builds
# (gradlew bundleRelease/assembleRelease) — regenerated every build, not source.
mobile/android/app/src/main/assets/
mobile/android/app/src/main/res/drawable-*/node_modules_*
mobile/android/app/src/main/res/drawable-*/src_*

# Android local files
mobile/android/local.properties
mobile/android/gradle.properties
mobile/android/app/google-services.json
mobile/android/app/release.keystore
mobile/android/app/oorumitra-release.keystore
mobile/android/app/oorumitra-release-2026.keystore
mobile/ios/GoogleService-Info.plist
# debug.keystore is intentionally committed (not secret)
# Release signing passwords live only in local gradle.properties (never committed)

# Environment / secrets
*.env
.env.*
# NOTE: application-prod.yml is now secret-free (all values come from env vars),
# so it is tracked and shipped in the image. Never add literal secrets to it.
backend/src/main/resources/firebase-service-account.json
deploy/.jwt-secret
deploy/.secrets

# IDE
.idea/
*.iml
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Coverage
coverage/

# Temp
.claude/
*.pptx
*.pdf

# Media & release artifacts (marketing assets, not source)
*.mp4
*.apk
whatsapp_status_*.png
